# Production: set in Vercel → Project → Settings → Environment Variables (all environments that build/serve the app)
# Must include /api suffix. Example:
# VITE_API_URL=https://your-service.onrender.com/api

VITE_API_URL=http://localhost:5000/api

# Dev only: Vite proxy target (backend base URL without /api path)
VITE_DEV_PROXY_TARGET=http://localhost:5000
