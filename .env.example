# Production (Vercel): set for every environment that runs `vite build`
# Use your Railway **origin** (with or without /api — both work):
#   VITE_API_URL=https://your-backend.up.railway.app
#   VITE_API_URL=https://your-backend.up.railway.app/api
#
# Local dev: either leave unset (use Vite proxy + /api) or point at your API root:
VITE_API_URL=http://localhost:5000/api

# Optional: set when using a custom ImageKit delivery domain.
# VITE_IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_imagekit_id

# Optional: comma-separated hero slide URLs (otherwise uses /hero-1.svg … in public/)
# VITE_HERO_IMAGES=https://cdn.example.com/banner1.jpg,https://...
